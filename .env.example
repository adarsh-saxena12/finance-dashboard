# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/finance_dashboard"

# Secret key for signing JWT tokens — use a long random string
JWT_SECRET="your_super_secret_jwt_key_here"

# JWT token expiry — 7d, 24h, 60m
JWT_EXPIRES_IN="7d"

# Allowed origins for CORS — use * for development
ALLOWED_ORIGINS="*"